generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model Shop {
  shop          String   @id
  isInstalled   Boolean  @default(true)
  installedAt   DateTime
  uninstalledAt DateTime?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model PricingRule {
  id                      String   @id @default(cuid())
  shop                    String   @unique
  markupPercent           Float    @default(10)
  charmPricing            Boolean  @default(true)
  roundingStep            Float    @default(1)
  liveMarkupPercent       Float?
  liveCharmPricing        Boolean?
  liveRoundingStep        Float?
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
  adjustmentType          String   @default("percentage")
  adjustmentDirection     String   @default("increase")
  adjustmentValue         Float    @default(10)
  endingOption            String   @default("0.99")
  roundingPrecision       String   @default("standard")
  minPrice                Float?
  maxPrice                Float?
  liveAdjustmentType      String?
  liveAdjustmentDirection String?
  liveAdjustmentValue     Float?
  liveEndingOption        String?
  liveRoundingPrecision   String?
  liveMinPrice            Float?
  liveMaxPrice            Float?
}

model Campaign {
  id          String    @id @default(uuid())
  shop        String
  title       String    @default("Pricing Campaign")
  status      String    @default("draft")
  runAt       DateTime?
  source      String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  windowEndAt DateTime?

  @@index([shop])
  @@index([shop, status])
  @@index([shop, runAt])
}

model PriceHistory {
  id                  String    @id @default(cuid())
  shop                String
  variantId           String
  oldPrice            Float
  newPrice            Float
  batchId             String
  createdAt           DateTime  @default(now())
  isManual            Boolean   @default(false)
  campaignId          String?
  revertStatus        String?
  revertedAt          DateTime?
  productId           String?
  revertFailureReason String?

  @@index([shop, campaignId])
  @@index([shop, batchId])
  @@index([campaignId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  shop      String
  action    String
  meta      Json?
  createdAt DateTime @default(now())
}

model Subscription {
  id        String   @id @default(cuid())
  shop      String   @unique
  plan      String
  status    String
  chargeId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PricingRuleHistory {
  id                  String   @id @default(cuid())
  shop                String
  markupPercent       Float
  charmPricing        Boolean
  roundingStep        Float
  createdAt           DateTime @default(now())
  adjustmentType      String?
  adjustmentDirection String?
  adjustmentValue     Float?
  endingOption        String?
  roundingPrecision   String?
  minPrice            Float?
  maxPrice            Float?
}

model StagedPrice {
  id            String   @id @default(uuid())
  shop          String
  variantId     String
  stagedPrice   Float
  originalPrice Float
  createdAt     DateTime @default(now())
  campaignId    String?
  isManual      Boolean  @default(false)
  productId     String?

  @@index([shop, campaignId])
  @@index([campaignId])
  @@index([shop, variantId])
}

model AppState {
  shop                       String    @id
  isLive                     Boolean   @default(false)
  onboardingFirstRuleAt       DateTime?
  onboardingFirstPreviewAt    DateTime?
  onboardingFirstApplyStartAt DateTime?
  onboardingFirstApplyAt      DateTime?
  onboardingFirstScheduleAt   DateTime?
  onboardingCompletedAt       DateTime?
  onboardingCelebratedAt      DateTime?
  reviewRequestShownAt        DateTime?
  reviewRequestDismissedAt    DateTime?
  activeCampaignId              String?
}

model PushJob {
  id          String   @id @default(uuid())
  shop        String
  operationId String?
  total       Int
  processed   Int      @default(0)
  success     Int      @default(0)
  failed      Int      @default(0)
  status      String   @default("running")
  createdAt   DateTime @default(now())
}

model ScheduledJob {
  id           String    @id @default(uuid())
  shop         String
  runAt        DateTime
  status       String    @default("pending")
  createdAt    DateTime  @default(now())
  campaignId   String?
  title        String    @default("Scheduled Campaign")
  productCount Int       @default(0)
  products     Json?
  mode         String    @default("one-time")
  windowEndAt  DateTime?
  activatedAt  DateTime?
  restoredAt   DateTime?

  @@index([shop, campaignId])
  @@index([campaignId])
  @@index([shop, status, windowEndAt])
}
