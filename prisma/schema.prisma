// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

// Note that some adapters may set a maximum length for the String type by default, please ensure your strings are long
// enough when changing adapters.
// See https://www.prisma.io/docs/orm/reference/prisma-schema-reference#string for more information
datasource db {
  provider = "postgresql" // ✅ Change to postgresql
  url      = env("DATABASE_URL")
}

model Session {
  id                  String    @id
  shop                String
  state               String
  isOnline            Boolean   @default(false)
  scope               String?
  expires             DateTime?
  accessToken         String
  userId              BigInt?
  firstName           String?
  lastName            String?
  email               String?
  accountOwner        Boolean   @default(false)
  locale              String?
  collaborator        Boolean?  @default(false)
  emailVerified       Boolean?  @default(false)
  refreshToken        String?
  refreshTokenExpires DateTime?
}

model PricingRule {
  id                String   @id @default(cuid())
  shop              String   @unique
  markupPercent     Float    @default(10)
  charmPricing      Boolean  @default(true)
  roundingStep      Float    @default(1)
  // Storefront live settings
  liveMarkupPercent Float?
  liveCharmPricing  Boolean?
  liveRoundingStep  Float?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model Campaign {
  id        String    @id @default(uuid())
  shop      String
  title     String    @default("Pricing Campaign")
  status    String    @default("draft")
  runAt     DateTime?
  source    String?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([shop])
  @@index([shop, status])
  @@index([shop, runAt])
}

model PriceHistory {
  id           String    @id @default(cuid())
  shop         String
  campaignId   String?
  productId    String?
  variantId    String
  oldPrice     Float
  newPrice     Float
  isManual     Boolean   @default(false) // NEW
  batchId      String
  revertStatus String?
  revertedAt   DateTime?
  revertFailureReason String?
  createdAt    DateTime  @default(now())

  @@index([shop, campaignId])
  @@index([shop, batchId])
  @@index([campaignId])
}

model ActivityLog {
  id        String   @id @default(cuid())
  shop      String
  action    String
  meta      Json?
  createdAt DateTime @default(now())
}

model Subscription {
  id        String   @id @default(cuid())
  shop      String   @unique
  plan      String
  status    String // active | cancelled
  chargeId  String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PricingRuleHistory {
  id            String   @id @default(cuid())
  shop          String
  markupPercent Float
  charmPricing  Boolean
  roundingStep  Float
  createdAt     DateTime @default(now())
}

model StagedPrice {
  id            String   @id @default(uuid())
  shop          String
  campaignId    String?
  variantId     String
  productId     String?
  stagedPrice   Float
  originalPrice Float
  isManual      Boolean  @default(false)
  createdAt     DateTime @default(now())

  @@index([shop, campaignId])
  @@index([campaignId])
  @@index([shop, variantId])
}

model AppState {
  shop   String  @id
  isLive Boolean @default(false)
}

model PushJob {
  id        String   @id @default(uuid())
  shop      String
  total     Int
  processed Int      @default(0)
  success   Int      @default(0)
  failed    Int      @default(0)
  status    String   @default("running") // running | done
  createdAt DateTime @default(now())
}

model ScheduledJob {
  id           String   @id @default(uuid())
  shop         String
  campaignId   String?
  runAt        DateTime
  status       String   @default("pending")
  createdAt    DateTime @default(now())
  title        String   @default("Scheduled Campaign")
  productCount Int      @default(0)
  products     Json?

  @@index([shop, campaignId])
  @@index([campaignId])
}
